# Required: Anthropic API key for the Claude Agent SDK
ANTHROPIC_API_KEY=

# Required: AgentMail API key for email ingestion
AGENTMAIL_API_KEY=

# Required in production: protects query, ingest, and lint endpoints
KB_ADMIN_TOKEN=

# Required in production: shared secret for AgentMail webhook calls
AGENTMAIL_WEBHOOK_SECRET=

# Required: Discord interactions endpoint verification
DISCORD_PUBLIC_KEY=

# Required only for registering slash commands with npm run discord:commands
DISCORD_APP_ID=
DISCORD_BOT_TOKEN=

# Optional: register commands to one guild for faster development updates
DISCORD_GUILD_ID=

# Optional: restrict command use to comma-separated Discord IDs
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_USER_IDS=
